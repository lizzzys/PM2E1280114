<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PM2E1280114.Pages.ListaSitios">

	<Shell.TitleView>
		<Label Text="Mis Sitios"
               TextColor="White"
               FontAttributes="Bold"
               FontSize="18"
               VerticalOptions="Center" />
	</Shell.TitleView>

	<CollectionView x:Name="listaSitios"
                    Margin="12"
                    BackgroundColor="#F0F4F8">
		<CollectionView.ItemTemplate>
			<DataTemplate>

				
				<Border Margin="0,6"
                        Padding="12"
                        Stroke="#2E6DA4"
                        StrokeThickness="1.5"
                        BackgroundColor="White">
					<Border.StrokeShape>
						<RoundRectangle CornerRadius="10" />
					</Border.StrokeShape>

					<Border.GestureRecognizers>
						<TapGestureRecognizer
                            NumberOfTapsRequired="2"
                            Tapped="OnDobleClick" />
					</Border.GestureRecognizers>

					<Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="12">

						<Image Grid.Column="0"
                               Source="{Binding RutaImagen}"
                               Aspect="AspectFill"
                               HeightRequest="70"
                               WidthRequest="70" />

						<VerticalStackLayout Grid.Column="1" Spacing="4">
							<Label Text="{Binding Descripcion}"
                                   FontAttributes="Bold"
                                   TextColor="#1B3A4B"
                                   FontSize="15" />
							<Label Text="{Binding Latitud, StringFormat='Lat: {0:F5}'}"
                                   TextColor="#555555" FontSize="12" />
							<Label Text="{Binding Longitud, StringFormat='Lon: {0:F5}'}"
                                   TextColor="#555555" FontSize="12" />
						</VerticalStackLayout>

						<Button Grid.Column="2"
                                Text="X"
                                BackgroundColor="#E53935"
                                TextColor="White"
                                CornerRadius="8"
                                WidthRequest="40"
                                HeightRequest="40"
                                Clicked="OnEliminar"
                                CommandParameter="{Binding .}" />
					</Grid>
				</Border>

			</DataTemplate>
		</CollectionView.ItemTemplate>
	</CollectionView>
</ContentPage>