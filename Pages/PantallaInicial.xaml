<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PM2E1280114.Pages.PantallaInicial"
             Title="Registrar Sitio">

    <ScrollView BackgroundColor="#FFFFFF">
        <VerticalStackLayout Padding="24" Spacing="16">

            <Label Text="Nuevo Sitio"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#F13E93"
                   HorizontalOptions="Center" />

            <Border Stroke="#F891BB"
                    StrokeThickness="2"
                    HeightRequest="200">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Image x:Name="imgSitio"
                       Aspect="AspectFill" />
            </Border>

            <Button Text="Tomar Foto"
                    BackgroundColor="#F891BB"
                    TextColor="White"
                    CornerRadius="10"
                    Clicked="OnTomarFoto" />

            <Entry x:Name="entDescripcion"
                   Placeholder="Descripcion del sitio"
                   PlaceholderColor="#F9D0CD"
                   BackgroundColor="#FFF5F7"
                   TextColor="#F13E93" />

            <HorizontalStackLayout Spacing="12">
                <Entry x:Name="entLatitud"
                       Placeholder="Latitud"
                       IsReadOnly="True"
                       BackgroundColor="#FFF5F7"
                       TextColor="#F13E93"
                       HorizontalOptions="FillAndExpand" />
                <Entry x:Name="entLongitud"
                       Placeholder="Longitud"
                       IsReadOnly="True"
                       BackgroundColor="#FFF5F7"
                       TextColor="#F13E93"
                       HorizontalOptions="FillAndExpand" />
            </HorizontalStackLayout>

            <Button Text="Obtener Ubicacion GPS"
                    BackgroundColor="#F9D0CD"
                    TextColor="#F13E93"
                    CornerRadius="10"
                    Clicked="OnObtenerUbicacion" />

            <Button Text="Guardar Sitio"
                    BackgroundColor="#F13E93"
                    TextColor="White"
                    CornerRadius="10"
                    Clicked="OnGuardar" />

            <Button Text="Ver Mis Sitios"
                    BackgroundColor="#F9D0CD"
                    TextColor="#F13E93"
                    CornerRadius="10"
                    Clicked="OnVerLista" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>